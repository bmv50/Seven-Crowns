# ─────────────────────────────────────────────────────────────
#  ЭХО ГЛУБИН — конфигурация окружения
#  Скопируйте этот файл в .env и заполните значения:
#      cp .env.example .env
#  Файл .env НЕ коммитится в git (см. .gitignore)
# ─────────────────────────────────────────────────────────────

# Токен Telegram-бота от @BotFather
BOT_TOKEN=ВСТАВЬ_СВОЙ_ТОКЕН

# Подключение к PostgreSQL
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/БАЗА
# Локально (WSL2) по умолчанию:
DATABASE_URL=postgresql://mud:mudpass@localhost:5432/mud

# Прокси для обхода блокировки Telegram (если api.telegram.org недоступен).
# Формат HTTP-прокси с авторизацией: http://ЛОГИН:ПАРОЛЬ@АДРЕС:ПОРТ
# Оставь пустым, если прокси не нужен.
PROXY_URL=

# ─────────────────────────────────────────────────────────────
#  ИИ-СЛОЙ (Этап 0: заглушка/локальная модель; пока можно не трогать)
#  Абстракция провайдера — переключение dev/prod одной переменной.
# ─────────────────────────────────────────────────────────────

# Провайдер моделей: none | deepseek
#   none     — ИИ выключен, NPC отвечают шаблонными репликами (как сейчас)
#   deepseek — живые реплики NPC через DeepSeek (OpenAI-совместимый API)
AI_PROVIDER=deepseek

# DeepSeek (нужен ключ с https://platform.deepseek.com):
DEEPSEEK_API_KEY=sk-ВСТАВЬ_СВОЙ_КЛЮЧ
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ───── Флаги мира (дефолты после спринта 7) ─────
# Семь флагов ниже включены ПО УМОЛЧАНИЮ (bot/main.py: os.environ.setdefault) —
# `python -m bot.main` запускает живой мир без доп. настройки. Явно заданное
# значение здесь/в окружении имеет приоритет над дефолтом. 0 — выключить, 1 — включить.
NPC_AI=1          # «живые» NPC вне боя: Utility AI + FSM (бродят/отдыхают/бегут раненые)
LAZY_SIM=1        # докрутка мира при входе игрока (catchup за время оффлайна)
WILD_ZONES=1      # генерация диких зон вокруг основного мира (нужен до импорта engine.content)
WORLD_EVENTS=1    # мировые ивенты (события на карте по таймеру)
SEASONS=1         # сезонный трек и лиги с ладдером
NOTIFY=1          # уведомления игроку (стрики, недельник и т.п.)
# ADMIN_IDS — Telegram uid администраторов через запятую (доступ к /admin:
# баны/муты, компенсации, пауза торговли, запуск событий, Health, LLM-статус).
# Пусто = админки нет. Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=
# RULES_V2 — гибридное ядро правил (типы урона/резисты/иммунитеты/уязвимости,
# спасброски от контроля, мультиатака, мировоззрение). ВКЛЮЧЁН по умолчанию
# (спринт 7). Мультиатака сбалансирована ещё в спринте 6 (rules2.multiattack_scale,
# +10.6%..+23.7% ΔDPS против мобов без широкого физ-резиста — внутри коридора
# ±25%). Последний блокер — профиль spirit (резистил СРАЗУ все физ. типы урона:
# bash/pierce/slash) — снят: дробящее (bash, освящённая булава/посох) сокрушает
# бесплотную форму и проходит, режущее/колющее (pierce/slash) по-прежнему
# резистится (см. rules2._CAT_PROFILE["spirit"]). Повторная проверка на данных
# (Monte-Carlo N=350×30, см. sim_rules2.py): против undead/demon/default — ВСЕ
# 6 классов на ур.15/45 в коридоре ±25% (36/36); против spirit — priest/paladin
# (дробящее оружие) и warrior (топор/меч) тоже в коридоре, mage/rogue/necromancer
# (кинжал/лук) осознанно проседают -25%..-41% (духи защищены от клинков), но у
# всех 6 классов 100% боевых скиллов уже нефизические (energy/fire/cold/poison) —
# контрплей есть всегда. Отключить явным RULES_V2=0, если нужно старое поведение.
RULES_V2=1

# ─────────────────────────────────────────────────────────────
#  ЭТАП 9: ДЕПЛОЙ / DOCKER
# ─────────────────────────────────────────────────────────────
# Учётные данные PostgreSQL для docker-compose (сервис postgres читает их как
# POSTGRES_*; из них же складывается DATABASE_URL). При запуске через compose
# ХОСТ в DATABASE_URL должен быть `postgres` (имя сервиса в compose-сети), а не
# localhost. Смените POSTGRES_PASSWORD на надёжный перед публичным запуском!
POSTGRES_USER=mud
POSTGRES_PASSWORD=mudpass
POSTGRES_DB=mud
# Для docker-compose раскомментируйте строку ниже (хост = postgres), она
# переопределит локальную DATABASE_URL выше:
# DATABASE_URL=postgresql://mud:mudpass@postgres:5432/mud

# PROD=1 — публичный (бета) режим: без БД процесс падает (fail-fast). В образе
# Docker уже выставлен PROD=1. Для локального dev без БД оставьте PROD пустым/0.
# PROD=1
# LOG_JSON=1 — структурные JSON-логи (в Docker включено по умолчанию).
# LOG_JSON=1
